{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": "Nationale-Nederlanden",
  "source": "https://www.nnespana.es/",
  "extracted": "2026-04-18",
  "color": {
    "Primary Orange": {
      "$type": "color",
      "$value": "#ea650d",
      "$description": "Primary brand color, buttons, links, and key interactive elements"
    },
    "Dark Gray Text": {
      "$type": "color",
      "$value": "#414141",
      "$description": "Primary text color for headings and body content"
    },
    "Blue Accent": {
      "$type": "color",
      "$value": "#0270e0",
      "$description": "Secondary accent color for links and interactive elements"
    },
    "White Background": {
      "$type": "color",
      "$value": "#ffffff",
      "$description": "Primary background color for main content areas"
    },
    "Button Gray": {
      "$type": "color",
      "$value": "#404040",
      "$description": "Secondary buttons and form elements"
    },
    "Light Gray Background": {
      "$type": "color",
      "$value": "#f1edeb",
      "$description": "Subtle background sections and cards"
    },
    "Border Gray": {
      "$type": "color",
      "$value": "#e5ded9",
      "$description": "Subtle borders and dividers"
    },
    "Dark Orange": {
      "$type": "color",
      "$value": "#e64415",
      "$description": "Darker orange variant for hover states"
    }
  },
  "typography": {
    "Heading Large": {
      "$type": "typography",
      "$value": {
        "fontFamily": "NNNittiGrotesk-Heading, Lato, system-ui, sans-serif",
        "fontSize": "36px",
        "fontWeight": 400,
        "lineHeight": "40px",
        "letterSpacing": "normal"
      },
      "$description": "Large headings and hero text"
    },
    "Heading Medium": {
      "$type": "typography",
      "$value": {
        "fontFamily": "NNNittiGrotesk-Heading, Lato, system-ui, sans-serif",
        "fontSize": "24px",
        "fontWeight": 400,
        "lineHeight": "28px",
        "letterSpacing": "normal"
      },
      "$description": "Section headings and subheadings"
    },
    "Body Regular": {
      "$type": "typography",
      "$value": {
        "fontFamily": "NNNittiGrotesk-Regular, Lato, system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": "22px",
        "letterSpacing": "normal"
      },
      "$description": "Standard body text and paragraphs"
    },
    "Body Medium": {
      "$type": "typography",
      "$value": {
        "fontFamily": "NNNittiGrotesk-Medium, Lato, system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": 500,
        "lineHeight": "24px",
        "letterSpacing": "normal"
      },
      "$description": "Emphasized body text and labels"
    }
  },
  "spacing": {
    "xs":  { "$type": "dimension", "$value": "4px"  },
    "sm":  { "$type": "dimension", "$value": "8px"  },
    "md":  { "$type": "dimension", "$value": "12px" },
    "lg":  { "$type": "dimension", "$value": "16px" },
    "xl":  { "$type": "dimension", "$value": "24px" },
    "2xl": { "$type": "dimension", "$value": "32px" },
    "3xl": { "$type": "dimension", "$value": "40px" }
  },
  "borderRadius": {
    "sm":   { "$type": "dimension", "$value": "2px"  },
    "md":   { "$type": "dimension", "$value": "4px"  },
    "lg":   { "$type": "dimension", "$value": "6px"  },
    "xl":   { "$type": "dimension", "$value": "8px"  },
    "pill": { "$type": "dimension", "$value": "25px" }
  }
}
