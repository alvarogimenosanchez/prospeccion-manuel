# Copia este archivo como .env y rellena los valores

# Anthropic (Claude API) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Supabase — https://supabase.com/dashboard/
SUPABASE_URL=https://uppcoebbimgvrzekadio.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Places API — https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# WhatsApp — Wassenger API (app.wassenger.com)
# Guía: app.wassenger.com → API → copiar token
WASSENGER_API_KEY=           # Token de la cuenta Wassenger
WASSENGER_DEVICE_ID=         # ID del número en Wassenger (opcional si solo tienes 1 número)
WASSENGER_WEBHOOK_SECRET=    # Secreto para verificar firma HMAC del webhook (app.wassenger.com → Webhooks → Secret)

# Número de WhatsApp de Manuel para recibir alertas de escalado (con código de país, ej: 34612345678)
MANUEL_WHATSAPP=

# Proxycurl API (opcional — para enriquecimiento LinkedIn)
PROXYCURL_API_KEY=

# URL del cuestionario público de captación (se incluye en mensajes IA)
CUESTIONARIO_URL=https://manuelasesora.es/captacion
