# Copia este archivo como .env y rellena los valores

# Anthropic (Claude API) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Supabase — https://supabase.com/dashboard/
SUPABASE_URL=https://uppcoebbimgvrzekadio.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Places API — https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# WhatsApp — Meta Cloud API (gratuito, sin intermediario)
# Guía: developers.facebook.com → App Business → Producto WhatsApp
WHATSAPP_ACCESS_TOKEN=       # Token permanente de System User (Admin)
WHATSAPP_PHONE_NUMBER_ID=    # ID del número en Meta Business (ej: 123456789012345)
WHATSAPP_APP_SECRET=         # App Secret del panel de la app en Meta (para verificar firma del webhook)
WHATSAPP_VERIFY_TOKEN=manuel_prospeccion_2024   # Token que pones en el webhook de Meta (no cambiar)

# Número de WhatsApp de Manuel para recibir alertas de escalado (con código de país, ej: 34612345678)
MANUEL_WHATSAPP=

# Proxycurl API (opcional — para enriquecimiento LinkedIn)
PROXYCURL_API_KEY=

# URL del cuestionario público de captación (se incluye en mensajes IA)
CUESTIONARIO_URL=https://manuelasesora.es/captacion
